# Local mode: leave the cloud variables empty. Local files are stored in ./.data.
PORT=3000
JWT_SECRET=replace_with_a_long_random_secret_at_least_32_characters
DATA_EXPORT_PATH=./.data

# Vercel production mode: set these in Vercel Project Settings > Environment Variables.
# POSTGRES_URL=postgresql://...
# BLOB_READ_WRITE_TOKEN=vercel_blob_rw_...
# ADMIN_USERNAME=admin
# ADMIN_PASSWORD=use_a_unique_password_of_at_least_12_characters
# SUPER_ADMIN_USERNAME=admin1
# SUPER_ADMIN_PASSWORD=use_a_different_unique_password_of_at_least_12_characters
